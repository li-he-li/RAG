# Backend Environment Configuration
# Copy this file to .env and adjust values as needed.

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=legalsearch
PG_PASSWORD=legalsearch
PG_DATABASE=legal_search

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Embedding provider: "google" or "local"
EMBEDDING_PROVIDER=google

# Google Embedding API (required when EMBEDDING_PROVIDER=google)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001

# Local embedding model (only used when EMBEDDING_PROVIDER=local)
# EMBEDDING_MODEL_NAME=BAAI/bge-m3

# Reranker model (always local)
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# DeepSeek V3 API (for match explanation generation)
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Retrieval rollout / fallback
# document_only | dual_no_explain | dual_full
RETRIEVAL_ROLLOUT_STAGE=dual_full
RETRIEVAL_ENABLE_FALLBACK=true

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Security (see ../SECURITY.md) ---
# Optional: require X-API-Key or Authorization: Bearer for all /api/* routes
# API_KEY=

# CORS: comma-separated origins, or * for any origin (credentials disabled with *)
# CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
# CORS_ALLOW_CREDENTIALS=true

# Max upload size in bytes (default 52428800 = 50 MiB)
# MAX_UPLOAD_BYTES=52428800

# DEBUG=true exposes exception text in some 500 responses (do not use in production)
# DEBUG=false

# API rate limit per IP per minute for /api/* (0 = disabled)
# RATE_LIMIT_PER_MINUTE=120

# Max JSON / NDJSON body size (non-multipart), bytes (default 8388608 = 8 MiB)
# MAX_JSON_BODY_BYTES=8388608

# Optional: restrict Host header (comma-separated). Example: localhost,127.0.0.1,myapp.example.com
# TRUSTED_HOSTS=
