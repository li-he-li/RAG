# Backend Environment Configuration
# Copy this file to .env and adjust values as needed.

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=legalsearch
PG_PASSWORD=legalsearch
PG_DATABASE=legal_search

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Embedding provider: "google" or "local"
EMBEDDING_PROVIDER=google

# Google Embedding API (required when EMBEDDING_PROVIDER=google)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001

# Local embedding model (only used when EMBEDDING_PROVIDER=local)
# EMBEDDING_MODEL_NAME=BAAI/bge-m3

# Reranker model (always local)
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# DeepSeek V3 API (for match explanation generation)
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Retrieval rollout / fallback
# document_only | dual_no_explain | dual_full
RETRIEVAL_ROLLOUT_STAGE=dual_full
RETRIEVAL_ENABLE_FALLBACK=true

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
